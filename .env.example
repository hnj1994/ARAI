# ARIA SOC Platform — Environment Variables
# Copy this file to .env and fill in ALL required values.
# Do NOT commit .env to version control.

# ══════════════════════════════════════════════════════════════════
# WAZUH
# ══════════════════════════════════════════════════════════════════

# Base URL of the Wazuh Manager API
WAZUH_BASE_URL=https://127.0.0.1:55000

# Wazuh API username
WAZUH_USER=wazuh

# REQUIRED: Wazuh API password
# Set during Wazuh installation. Change with: wazuh-passwords-tool.sh
WAZUH_PASS=

# ══════════════════════════════════════════════════════════════════
# OPENSEARCH
# ══════════════════════════════════════════════════════════════════

# OpenSearch (Wazuh Indexer) base URL
OPENSEARCH_BASE_URL=https://127.0.0.1:9200

# REQUIRED: Base64-encoded "username:password" for OpenSearch
# Generate: echo -n "admin:YourPassword" | base64
# Example: admin:SecretPass123 → YWRtaW46U2VjcmV0UGFzczEyMw==
OPENSEARCH_AUTH=

# REQUIRED: Same value as OPENSEARCH_AUTH — used by Nginx to inject
# the Authorization header server-side (browser never sees this)
# Generate: echo -n "admin:YourPassword" | base64
OPENSEARCH_BASIC_AUTH=

# ══════════════════════════════════════════════════════════════════
# OLLAMA (Local AI)
# ══════════════════════════════════════════════════════════════════

# Ollama API base URL (must be reachable from the Docker network)
# If Ollama runs on the host: use host.docker.internal on macOS/Windows
# On Linux: use the Docker bridge IP (usually 172.17.0.1)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Ollama model to use — must be pulled first: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# ══════════════════════════════════════════════════════════════════
# REDIS (internal — no external access)
# ══════════════════════════════════════════════════════════════════

# Redis connection URL — use service name in Docker Compose
REDIS_URL=redis://redis:6379

# ══════════════════════════════════════════════════════════════════
# APPLICATION
# ══════════════════════════════════════════════════════════════════

# REQUIRED: JWT signing secret — must be 32+ random characters
# Generate: openssl rand -hex 32
# NOTE: This must match the secret Wazuh uses to sign its JWTs,
#       OR use the payload-decode fallback (see middleware/auth.py)
JWT_SECRET=

# Minimum Wazuh alert level to process (1-15)
# Level 7 = medium severity, 10 = high, 13 = critical
MIN_ALERT_LEVEL=7

# Application log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Alert polling interval in seconds
POLL_INTERVAL=5
